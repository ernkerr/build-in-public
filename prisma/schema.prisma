generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model IngestItem {
  id        String   @id @default(cuid())
  source    String // 'github' | 'notes'
  content   String
  metadata  String   @default("{}") // JSON string
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  drafts    Draft[]
}

model Draft {
  id           String      @id @default(cuid())
  platform     String // 'x' | 'linkedin' | 'threads'
  content      String
  status       String      @default("pending") // 'pending' | 'approved' | 'rejected' | 'published' | 'scheduled'
  batchId      String
  imageUrl     String? // path to uploaded image in public/uploads/
  scheduledAt  DateTime? // when to auto-publish (null = not scheduled)
  publishedUrl String? // URL of the published post
  ingestItemId String?
  ingestItem   IngestItem? @relation(fields: [ingestItemId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model StyleReference {
  id        String   @id @default(cuid())
  platform  String // 'x' | 'linkedin' | 'threads'
  content   String
  source    String // 'scraped' | 'manual'
  handle    String?
  createdAt DateTime @default(now())
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
